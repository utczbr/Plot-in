# services/legend_matching_service.py (NEW FILE)
"""
Minimal Viable Implementation of a Legend Matching Service.
Matches pie slices to legend labels based on color similarity.
"""
import numpy as np
import cv2
import logging
from typing import List, Dict, Any, Optional

class LegendMatchingService:

    def __init__(self, logger: Optional[logging.Logger] = None):
        self.logger = logger or logging.getLogger(self.__class__.__name__)
        self._is_healthy = True

    def is_healthy(self) -> bool:
        return self._is_healthy

    def match_slices_to_legend(
        self,
        slices_data: List[Dict[str, Any]],
        legend_elements: List[Dict[str, Any]],
        image: np.ndarray
    ) -> List[Dict[str, Any]]:
        """
        Matches pie slices to legend labels using color similarity.
        
        Args:
            slices_data: List of slice dictionaries (from PieHandler).
            legend_elements: List of legend label detections with OCR text.
            image: Input image for color sampling.
            
        Returns:
            The modified slices_data list with 'label' fields updated.
        """
        if not legend_elements:
            return slices_data
        
        # Extract legend label colors and texts
        legend_data = []
        for leg_elem in legend_elements:
            leg_color = self._sample_legend_color(image, leg_elem["xyxy"])
            leg_text = leg_elem.get("text", "Unknown")
            legend_data.append({
                "text": leg_text,
                "color": leg_color,
                "bbox": leg_elem["xyxy"]
            })
        
        # Match each slice to best legend entry
        for slice_info in slices_data:
            best_match_idx = -1
            best_color_distance = float('inf')
            
            slice_color = slice_info["color_rgb"]
            
            for leg_idx, leg_info in enumerate(legend_data):
                # Compute Euclidean color distance in RGB space
                color_dist = np.linalg.norm(slice_color - leg_info["color"])
                
                if color_dist < best_color_distance:
                    best_color_distance = color_dist
                    best_match_idx = leg_idx
            
            # Assign label if match is confident (threshold from critique)
            if best_match_idx >= 0 and best_color_distance < 100:
                slice_info["label"] = legend_data[best_match_idx]["text"]
            else:
                self.logger.warning(
                    f"Slice {slice_info['slice_id']} (color {slice_color}) "
                    f"failed to match legend (best dist: {best_color_distance})"
                )
                # Keep default label "Slice X"
        
        return slices_data

    def _sample_legend_color(
        self, 
        image: np.ndarray, 
        xyxy: List[float]
    ) -> np.ndarray:
        """Samples color from legend label background."""
        x1, y1, x2, y2 = map(int, xyxy)
        
        # Sample left 30% of legend box (where color indicator usually is)
        w = x2 - x1
        color_region_x2 = x1 + max(int(w * 0.3), 1) # Ensure at least 1px
        
        color_crop = image[y1:y2, x1:color_region_x2]
        
        if color_crop.size == 0:
            return np.array([128, 128, 128])
        
        color_rgb = cv2.cvtColor(color_crop, cv2.COLOR_BGR2RGB)
        median_color = np.median(color_rgb.reshape(-1, 3), axis=0)
        
        return median_color.astype(np.uint8)
