"""
Thread-safe singleton for model management with support for diverse model types.
"""

import threading
from pathlib import Path
import onnxruntime as ort
import onnx # For model validation
import logging
from typing import Dict, Optional


class ModelManager:
    """Thread-safe singleton for model management."""
    
    _instance = None
    _models = None
    _lock = threading.Lock()
    
    # Model type registry (defines expected output format)
    MODEL_TYPES = {
        'classification': 'bbox',
        'bar': 'bbox',
        'box': 'bbox',
        'line': 'bbox',
        'scatter': 'bbox',
        'histogram': 'bbox',
        'heatmap': 'bbox',             # NEW: Standard bbox for cells
        'pie': 'keypoint'              # NEW: Keypoint-based detection
    }
    
    MODEL_FILES = {
        'classification': 'classification.onnx',
        'bar': 'detect_bar.onnx',
        'box': 'detect_box.onnx',
        'line': 'detect_line.onnx',
        'scatter': 'detect_scatter.onnx',
        'histogram': 'detect_histogram.onnx',
        'heatmap': 'detect_heatmap.onnx',    # NEW
        'pie': 'detect_pie_keypoint.onnx'    # NEW: Keypoint model
    }
    
    def __new__(cls):
        # ... (singleton logic unchanged) ...
    
    def load_models(self, models_dir: str) -> Dict[str, ort.InferenceSession]:
        """
        Loads models once and reuses across all images.
        """
        if self._models is not None:
            return self._models
        
        with self._lock:
            if self._models is not None:
                return self._models
            
            self._models = {}
            models_path = Path(models_dir)
            
            for model_name, filename in self.MODEL_FILES.items():
                model_path = models_path / filename
                if model_path.exists():
                    try:
                        # 5.2.3 Model File Integrity Validation
                        self._validate_model_file(model_path, model_name)
                        
                        session = ort.InferenceSession(
                            str(model_path),
                            providers=['CUDAExecutionProvider', 'CPUExecutionProvider']
                        )
                        self._models[model_name] = session
                        
                        model_type = self.MODEL_TYPES.get(model_name, 'bbox')
                        logging.info(
                            "✓ Loaded %s (%s, %.1fKB, type: %s)",
                            model_name,
                            filename,
                            model_path.stat().st_size / 1024,
                            model_type
                        )
                    except Exception as e:
                        logging.error(
                            "Failed to load model %s: %s",
                            model_name, e, exc_info=True
                        )
                else:
                    logging.warning("Model file not found: %s", model_path)
            
            return self._models

    def _validate_model_file(self, model_path: Path, model_name: str):
        """Performs integrity checks on the ONNX model file."""
        if model_path.stat().st_size < 1_000_000: # 1MB
             raise SystemError(f"Model file {model_path} is suspiciously small.")
        
        try:
            onnx_model = onnx.load(str(model_path))
            onnx.checker.check_model(onnx_model)
        except Exception as e:
            raise SystemError(f"ONNX model integrity check failed for {model_path}: {e}")
        
        # TODO: Add input/output shape validation
        
    
    def get_model(self, model_name: str) -> Optional[ort.InferenceSession]:
        # ... (unchanged) ...
    
    def get_model_type(self, model_name: str) -> str:
        """
        Returns the output type of a model ('bbox' or 'keypoint').
        """
        return self.MODEL_TYPES.get(model_name, 'bbox')
