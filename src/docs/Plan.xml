# handlers/pie_handler.py (NEW FILE)
"""
Handler for extracting data from pie charts using keypoint-based slice detection.
"""

from typing import Dict, List, Any, Optional, Tuple
import numpy as np
import cv2
import logging
from collections import defaultdict

from handlers.base_handler import PolarChartHandler, ExtractionResult, ChartCoordinateSystem
from services.orientation_service import Orientation
from core.detection_types import KeypointDetection


class PieHandler(PolarChartHandler):
    """
    Extracts percentage values from pie chart slices using keypoint geometry.
    
    Keypoint Structure (per slice):
    - kpt[0]: Center of pie
    - kpt[1]: Start point of arc
    - kpt[2]: Arc intermediate point 1
    - kpt[3]: Arc intermediate point 2
    - kpt[4]: End point of arc
    """
    
    COORDINATE_SYSTEM = ChartCoordinateSystem.POLAR
    
    def process(
        self,
        image: np.ndarray,
        detections: Dict[str, Any],
        axis_labels: List[Dict],  # Not used
        chart_elements: List[KeypointDetection],  # Pie slices with keypoints
        orientation: Orientation,  # Not used
        **kwargs
    ) -> ExtractionResult:
        """
        Processes a pie chart.
        """
        self.logger.info(
            "Processing pie chart with %d slices",
            len(chart_elements)
        )
        
        result = ExtractionResult(
            chart_type="pie",
            coordinate_system=self.COORDINATE_SYSTEM,
            orientation=Orientation.NOT_APPLICABLE
        )
        
        try:
            if not chart_elements:
                result.errors.append("No pie slices detected")
                return result
            
            # Step 1: Determine global pie center
            pie_center = self._compute_global_center(chart_elements)
            self.logger.debug("Computed global pie center: (%.1f, %.1f)", *pie_center)
            
            # Step 2: Compute angle and percentage for each slice
            slices_data = []
            total_angle = 0.0
            
            for slice_idx, slice_det in enumerate(chart_elements):
                slice_info = self._process_slice(
                    slice_det, 
                    pie_center, 
                    slice_idx,
                    image # Pass image for color sampling
                )
                if slice_info:
                    slices_data.append(slice_info)
                    total_angle += slice_info["angle_degrees"]
            
            if not slices_data:
                result.errors.append("Failed to process any slices")
                return result
            
            # Step 3: Normalize percentages (Critique 3.2.5)
            angle_error = abs(total_angle - 360.0)
            if angle_error > 30.0:
                result.errors.append(f"Pie chart total angle {total_angle}° deviates too much from 360°")
                return result
            elif angle_error > 5.0:
                result.warnings.append(f"Pie chart angle error: {angle_error}°, normalizing")
                self._normalize_angles_and_percentages(slices_data, total_angle)
            
            # Ensure percentages sum to exactly 100%
            self._ensure_100_percent_sum(slices_data)

            # Step 4: Match slices to legend labels
            legend_elements = kwargs.get("legend_elements", [])
            if legend_elements and self.legend_matcher:
                # Use the injected service
                slices_data = self.legend_matcher.match_slices_to_legend(
                    slices_data, 
                    legend_elements, 
                    image
                )
            elif legend_elements:
                result.warnings.append("No legend matcher service, slices will have generic labels")
            
            # Step 5: Sort slices by angle
            slices_data.sort(key=lambda s: s["start_angle"])
            
            # Format output
            result.elements = [
                {
                    "slice_id": s["slice_id"],
                    "label": s["label"],
                    "percentage": s["percentage"],
                    "angle_degrees": s["angle_degrees"],
                    "start_angle": s["start_angle"],
                    "end_angle": s["end_angle"],
                    "color_rgb": s["color_rgb"].tolist(),
                    "confidence": s["confidence"]
                }
                for s in slices_data
            ]
            
            result.diagnostics = {
                "total_slices": len(chart_elements),
                "processed_slices": len(slices_data),
                "total_angle_raw": total_angle,
                "angle_error_raw": angle_error,
                "was_normalized": angle_error > 5.0,
                "has_legend": len(legend_elements) > 0,
                "legend_matcher_active": self.legend_matcher is not None,
                "pie_center": pie_center
            }
            
        except Exception as e:
            self.logger.error("Pie chart processing failed: %s", e, exc_info=True)
            result.errors.append(f"Processing error: {str(e)}")
        
        return result
    
    def _compute_global_center(
        self, 
        slices: List[KeypointDetection]
    ) -> Tuple[float, float]:
        """
        Computes the global pie center as the median of all slice centers (kpt 0).
        """
        centers = []
        for slice_det in slices:
            kpt = slice_det.get_keypoint(0)  # Keypoint 0 is slice center
            if kpt:
                centers.append((kpt[0], kpt[1]))
        
        if not centers:
            # Fallback: use median of bounding box centers
            self.logger.warning("No valid kpt[0] for center, falling back to bbox centers")
            centers = [
                ((s.xyxy[0] + s.xyxy[2]) / 2, (s.xyxy[1] + s.xyxy[3]) / 2)
                for s in slices
            ]
        
        if not centers: return (0, 0) # Should not happen if slices exist
        
        centers_array = np.array(centers)
        median_center = np.median(centers_array, axis=0)
        return tuple(median_center)
    
    def _process_slice(
        self,
        slice_det: KeypointDetection,
        pie_center: Tuple[float, float],
        slice_idx: int,
        image: np.ndarray
    ) -> Optional[Dict[str, Any]]:
        """
        Computes geometric properties of a single slice.
        """
        # Extract keypoints
        kpt_start = slice_det.get_keypoint(1)  # Arc start
        kpt_end = slice_det.get_keypoint(4)    # Arc end
        
        if not kpt_start or not kpt_end:
            self.logger.warning(
                "Slice %d missing required keypoints (start=kpt[1] or end=kpt[4])",
                slice_idx
            )
            return None
        
        cx, cy = pie_center
        
        # Compute angles using atan2
        start_angle_rad = np.arctan2(kpt_start[1] - cy, kpt_start[0] - cx)
        end_angle_rad = np.arctan2(kpt_end[1] - cy, kpt_end[0] - cx)
        
        # Convert to degrees [0, 360)
        start_angle = np.degrees(start_angle_rad) % 360
        end_angle = np.degrees(end_angle_rad) % 360
        
        # Compute angular span (handle wraparound)
        angle_span = end_angle - start_angle
        if angle_span <= 0: # Use <= 0 to handle small negative spans and 0
            angle_span += 360
        
        # Sample slice color
        slice_color = self._sample_slice_color(slice_det, image)
        
        return {
            "slice_id": slice_idx,
            "start_angle": start_angle,
            "end_angle": end_angle,
            "angle_degrees": angle_span,
            "percentage": (angle_span / 360.0) * 100.0, # Initial percentage
            "color_rgb": slice_color,
            "confidence": slice_det.conf,
            "label": f"Slice {slice_idx}",  # Default label
            "bbox": slice_det.xyxy
        }
    
    def _normalize_angles_and_percentages(
        self, 
        slices_data: List[Dict], 
        total_angle: float
    ):
        """
        Normalizes slice angles and percentages to sum to 360° and 100%.
        """
        if total_angle == 0:
            return
        
        normalization_factor = 360.0 / total_angle
        
        for slice_info in slices_data:
            slice_info["angle_degrees"] *= normalization_factor
            slice_info["percentage"] = (slice_info["angle_degrees"] / 360.0) * 100.0

    def _ensure_100_percent_sum(self, slices_data: List[Dict]):
        """Distribute rounding error to largest slice."""
        if not slices_data: return

        percentage_total = sum(s["percentage"] for s in slices_data)
        if abs(percentage_total - 100.0) > 0.01:
            # Find largest slice
            largest_slice = max(slices_data, key=lambda s: s["percentage"])
            largest_slice["percentage"] += (100.0 - percentage_total)
    
    def _sample_slice_color(
        self, 
        slice_det: KeypointDetection,
        image: np.ndarray
    ) -> np.ndarray:
        """
        Samples the dominant color of a pie slice.
        """
        x1, y1, x2, y2 = map(int, slice_det.xyxy)
        
        # Crop to central 50%
        w, h = x2 - x1, y2 - y1
        margin_x, margin_y = int(w * 0.25), int(h * 0.25)
        cx1, cy1 = max(x1 + margin_x, x1), max(y1 + margin_y, y1)
        cx2, cy2 = min(x2 - margin_x, x2), min(y2 - margin_y, y2)
        if cx2 <= cx1 or cy2 <= cy1: cx1, cy1, cx2, cy2 = x1, y1, x2, y2
        
        slice_crop = image[cy1:cy2, cx1:cx2]
        
        if slice_crop.size == 0:
            return np.array([128, 128, 128])
        
        slice_rgb = cv2.cvtColor(slice_crop, cv2.COLOR_BGR2RGB)
        median_color = np.median(slice_rgb.reshape(-1, 3), axis=0)
        
        return median_color.astype(np.uint8)
