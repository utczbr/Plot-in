# image_processor.py (REFACTORED SECTION)

from core.detection_types import BoundingBox, KeypointDetection, DetectionResult
import logging # Ensure logging is imported

def _run_detection(
    model: Any, 
    image: np.ndarray, 
    chart_type: str,
    class_map: Dict[int, str],
    model_manager: 'ModelManager' # Added for model type checking
) -> DetectionResult:
    """
    Runs object detection with support for bounding boxes and keypoints.
    
    Args:
        model: ONNX model session.
        image: Input image.
        chart_type: Type of chart (determines detection mode).
        class_map: Mapping from class IDs to names.
        model_manager: The ModelManager instance.
    
    Returns:
        DetectionResult containing all detections with appropriate format.
    """
    import time
    start_time = time.time()
    
    # Determine confidence threshold
    if chart_type == "histogram":
        conf_threshold = 0.4 # From original file
    elif chart_type == "heatmap":
        conf_threshold = 0.3  # Heatmaps have many cells, lower threshold
    else:
        conf_threshold = 0.5 # From original file (DEFAULT_DETECTION_THRESHOLD)
    
    # Check model output type
    model_output_type = model_manager.get_model_type(chart_type)
    model_outputs_keypoints = (model_output_type == 'keypoint')
    
    # Run inference (this function needs to be enhanced to return keypoints)
    # Assumes run_inference_on_image is refactored to handle this
    try:
        raw_detections = run_inference_on_image(
            model, image, conf_threshold, class_map,
            return_keypoints=model_outputs_keypoints
        )
    except Exception as e:
        logging.error(f"ONNX inference failed: {e}", exc_info=True)
        return DetectionResult(
            bboxes=[],
            keypoint_detections=[],
            detections_by_class={name: [] for name in class_map.values()},
            metadata={"error": str(e), "inference_time": 0.0}
        )
    
    inference_time = time.time() - start_time
    logging.info(
        "Detection for '%s' found %d objects (%.2fs)",
        chart_type, len(raw_detections), inference_time
    )
    
    # Organize detections by type
    bboxes: List[BoundingBox] = []
    keypoint_detections: List[KeypointDetection] = []
    detections_by_class: Dict[str, List[Any]] = {name: [] for name in class_map.values()}
    
    for det in raw_detections:
        class_name = class_map.get(det["cls"], "unknown")
        
        if model_outputs_keypoints and "keypoints" in det and det["keypoints"] is not None:
            # Keypoint-based detection (pie slices)
            
            # VALIDATION (from critique)
            kpts = np.array(det["keypoints"])
            if kpts.ndim != 2 or kpts.shape[1] != 3:
                logging.warning(f"Skipping malformed keypoint data. Expected (N, 3), got {kpts.shape}")
                continue
            
            # Pie-specific validation
            if chart_type == "pie" and kpts.shape[0] != 5:
                 logging.warning(f"Pie slice keypoints have wrong count. Expected 5, got {kpts.shape[0]}")
                 # Continue, but this slice may fail processing
            
            kpt_det = KeypointDetection(
                xyxy=det["xyxy"],
                cls=det["cls"],
                conf=det["conf"],
                class_name=class_name,
                keypoints=kpts
            )
            keypoint_detections.append(kpt_det)
            detections_by_class[class_name].append(kpt_det)
        else:
            # Standard bounding box detection
            bbox_det = BoundingBox(
                xyxy=det["xyxy"],
                cls=det["cls"],
                conf=det["conf"],
                class_name=class_name
            )
            bboxes.append(bbox_det)
            detections_by_class[class_name].append(bbox_det)
    
    return DetectionResult(
        bboxes=bboxes,
        keypoint_detections=keypoint_detections,
        detections_by_class=detections_by_class,
        metadata={
            "chart_type": chart_type,
            "inference_time": inference_time,
            "total_detections": len(raw_detections),
            "bbox_count": len(bboxes),
            "keypoint_count": len(keypoint_detections),
            "model_output_type": model_output_type
        }
    )
