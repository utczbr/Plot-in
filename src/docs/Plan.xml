# services/color_mapping_service.py (NEW FILE)
"""
Minimal Viable Implementation of a Color Mapping Service.
Extracts a continuous color scale from a color bar.
"""
import numpy as np
import cv2
import logging
from typing import Callable, List, Tuple, Dict, Any

class ColorMappingService:
    
    def __init__(self, logger: Optional[logging.Logger] = None):
        self.logger = logger or logging.getLogger(self.__class__.__name__)
        self._is_healthy = True

    def is_healthy(self) -> bool:
        return self._is_healthy

    def extract_color_scale(
        self, 
        image: np.ndarray, 
        color_bar_bbox: Dict[str, Any]
    ) -> Callable[[np.ndarray], float]:
        """
        Extracts color scale from color bar and returns a mapping function.
        
        Args:
            image: Full image.
            color_bar_bbox: Bounding box of the color bar.
            
        Returns:
            A function that takes an RGB color and returns a float value.
        """
        try:
            x1, y1, x2, y2 = map(int, color_bar_bbox["xyxy"])
            
            # TODO: Add logic to find color bar axis labels for min/max
            # For MVP, assume 0.0 (bottom/left) to 1.0 (top/right)
            min_val = 0.0
            max_val = 1.0
            
            # Crop color bar
            bar_crop = image[y1:y2, x1:x2]
            h, w = bar_crop.shape[:2]
            
            # Sample 50 points along the dominant axis
            if h > w: # Vertical bar
                sample_points_y = np.linspace(h - 1, 0, 50, dtype=int) # Bottom to Top
                sample_points_x = np.full(50, w // 2, dtype=int)
            else: # Horizontal bar
                sample_points_x = np.linspace(0, w - 1, 50, dtype=int) # Left to Right
                sample_points_y = np.full(50, h // 2, dtype=int)

            colors = bar_crop[sample_points_y, sample_points_x]
            colors_rgb = cv2.cvtColor(colors.reshape(-1, 1, 3), cv2.COLOR_BGR2RGB).reshape(-1, 3)
            
            # Create scale (list of (RGB, value))
            scale_values = np.linspace(min_val, max_val, 50)
            self.scale = list(zip(colors_rgb, scale_values))
            
            self.logger.debug("Successfully extracted color scale with 50 points")

            def mapper(rgb_color: np.ndarray) -> float:
                """Finds nearest color in scale and returns its value."""
                if not self.scale: return 0.0
                
                # Find nearest color by Euclidean distance
                distances = [np.linalg.norm(rgb_color - scale_color) for scale_color, _ in self.scale]
                best_match_idx = np.argmin(distances)
                return self.scale[best_match_idx][1]

            return mapper

        except Exception as e:
            self.logger.error(f"Failed to extract color scale: {e}", exc_info=True)
            return self._create_default_color_mapper()

    def _create_default_color_mapper(self):
        """Grayscale intensity fallback."""
        def mapper(rgb_color: np.ndarray) -> float:
            gray = 0.299 * rgb_color[0] + 0.587 * rgb_color[1] + 0.114 * rgb_color[2]
            return gray / 255.0
        return mapper
