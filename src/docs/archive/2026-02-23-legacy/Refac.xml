    detection_model = models.get_model(chart_type)
    if not detection_model:
        logging.error("No detection model for chart type '%s'", chart_type)
        return None
    
    class_map = get_class_map(chart_type)
    detection_result = _run_detection(detection_model, image, chart_type, class_map)
    
    # 3. Handle chart-type-specific processing
    if chart_type == "heatmap":
        # For heatmaps, we have thousands of cells - optimize memory
        logging.info(
            "Processing heatmap with %d cells, %d axis_labels",
            len(detection_result.detections_by_class.get("cell", [])),
            len(detection_result.detections_by_class.get("axis_labels", []))
        )
        # Skip OCR on individual cells (not needed), only on axis labels
        axis_labels = detection_result.detections_by_class.get("axis_labels", [])
        _perform_ocr(ocr_engine, image, axis_labels)
        
        # Pass cells directly to handler without further processing
        chart_elements = detection_result.detections_by_class.get("cell", [])
        orientation = Orientation.NOT_APPLICABLE  # Heatmaps don't have orientation
    
    elif chart_type == "pie":
        # For pie charts, orientation is not applicable
        logging.info(
            "Processing pie chart with %d slices (keypoint detections)",
            len(detection_result.keypoint_detections)
        )
        axis_labels = []  # Pie charts don't have axis labels
        chart_elements = detection_result.keypoint_detections  # Pass keypoint data
        orientation = Orientation.NOT_APPLICABLE
        
        # Extract legend for label matching
        legend_elements = detection_result.detections_by_class.get("legend", [])
        if legend_elements:
            _perform_ocr(ocr_engine, image, legend_elements)
    
