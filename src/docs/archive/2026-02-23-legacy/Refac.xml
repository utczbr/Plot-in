"""
Type definitions for diverse detection outputs (bounding boxes + keypoints).
"""

from dataclasses import dataclass
from typing import List, Optional, Dict, Any
import numpy as np


@dataclass
class BoundingBox:
    """Standard bounding box detection."""
    xyxy: List[float]  # [x1, y1, x2, y2]
    cls: int
    conf: float
    class_name: str
    
    def get_center(self) -> tuple[float, float]:
        """Returns (cx, cy) center coordinates."""
        x1, y1, x2, y2 = self.xyxy
        return ((x1 + x2) / 2, (y1 + y2) / 2)
    
    def get_area(self) -> float:
        """Returns bounding box area."""
        x1, y1, x2, y2 = self.xyxy
        return (x2 - x1) * (y2 - y1)


@dataclass
class KeypointDetection:
    """Detection with keypoint annotations (for pie slices, pose estimation)."""
    xyxy: List[float]  # Bounding box
    cls: int
    conf: float
    class_name: str
    keypoints: np.ndarray  # Shape: (num_keypoints, 3) with columns [x, y, confidence]
    
    def get_keypoint(self, index: int) -> Optional[tuple[float, float, float]]:
        """Returns (x, y, conf) for keypoint at index, or None if invalid."""
        if 0 <= index < len(self.keypoints):
            kpt = self.keypoints[index]
            if kpt[2] > 0:  # Confidence > 0 means visible
                return tuple(kpt)
        return None


@dataclass
class DetectionResult:
    """
    Unified detection result supporting both bounding boxes and keypoints.
    
    Attributes:
        bboxes: List of bounding box detections.
        keypoint_detections: List of keypoint-based detections (e.g., pie slices).
        detections_by_class: Organized detections by class name.
        metadata: Additional info (e.g., model type, inference time).
    """
    bboxes: List[BoundingBox]
    keypoint_detections: List[KeypointDetection]
    detections_by_class: Dict[str, List[Any]]
    metadata: Dict[str, Any]
