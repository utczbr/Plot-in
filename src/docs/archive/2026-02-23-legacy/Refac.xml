2. Extract X and Y axis labels via OCR
3. For each cell: determine its row/column via spatial binning
4. Sample cell color and map to numeric value using color bar
5. Associate optional data labels and significance markers
"""

from typing import Dict, List, Any, Optional, Tuple
import numpy as np
import cv2
from collections import defaultdict
import logging

from handlers.base_handler import GridChartHandler, ExtractionResult, ChartCoordinateSystem
from services.orientation_service import Orientation


class HeatmapHandler(GridChartHandler):
    """
    Extracts structured data from heatmap charts with thousands of cells.
    
    **Performance Optimizations:**
    - Spatial binning instead of exhaustive distance calculations
    - Vectorized color sampling
    - Early termination for missing labels
    """
    
    COORDINATE_SYSTEM = ChartCoordinateSystem.GRID
    
    def process(
        self,
        image: np.ndarray,
        detections: Dict[str, Any],
        axis_labels: List[Dict],
        chart_elements: List[Dict],  # cells
        orientation: Orientation,
        **kwargs
    ) -> ExtractionResult:
        """
        Processes a heatmap chart.
        
        Args:
            image: Input image array.
            detections: All detected elements by class.
            axis_labels: X and Y axis labels with OCR text.
            chart_elements: List of cell bounding boxes (thousands of them).
            orientation: Ignored for heatmaps.
            **kwargs: Optional parameters.
        
        Returns:
            ExtractionResult with matrix data.
        """
        self.logger.info(
            "Processing heatmap with %d cells, %d axis labels",
            len(chart_elements), len(axis_labels)
        )
        
        result = ExtractionResult(
            chart_type="heatmap",
            coordinate_system=self.COORDINATE_SYSTEM,
            orientation=Orientation.NOT_APPLICABLE
        )
        
        try:
            # Step 1: Separate and sort axis labels into X and Y
            x_labels, y_labels = self._classify_axis_labels(
                axis_labels, 
                chart_elements, 
                image.shape
            )
            
            if not x_labels or not y_labels:
                result.errors.append("Insufficient axis labels for heatmap reconstruction")
                return result
            
            self.logger.info(
                "Classified %d X-labels and %d Y-labels",
                len(x_labels), len(y_labels)
            )
            
            # Step 2: Build spatial index for efficient cell-label matching
            x_bins = self._create_spatial_bins(x_labels, axis='x')
            y_bins = self._create_spatial_bins(y_labels, axis='y')
            
            # Step 3: Extract color bar mapping (color -> value)
            color_bar = detections.get("color_bar", [])
            data_labels_dict = detections.get("data_label", [])
            
            if not color_bar:
                result.warnings.append("No color bar detected, using default color mapping")
                value_mapper = self._create_default_color_mapper()
            else:
                value_mapper = self.color_mapper.extract_color_scale(
                    image, color_bar[0]
                )
            
            # Step 4: Process each cell
            elements = []
            for cell_idx, cell in enumerate(chart_elements):
                cx, cy = self._get_bbox_center(cell["xyxy"])
                
                # Find row and column via spatial binning
                col_idx, col_label = self._find_bin(cx, x_bins, x_labels)
                row_idx, row_label = self._find_bin(cy, y_bins, y_labels)
                
                if col_idx is None or row_idx is None:
                    continue  # Cell outside grid boundaries
                
                # Sample cell color
                cell_color = self._sample_cell_color(image, cell["xyxy"])
                
                # Map color to value
                cell_value = value_mapper(cell_color)
                
                # Check for data label overlapping this cell
                data_label_text = self._find_overlapping_data_label(
                    cell["xyxy"], data_labels_dict
                )
                
                element = {
                    "row": row_idx,
                    "col": col_idx,
                    "row_label": row_label,
                    "col_label": col_label,
                    "value": cell_value,
                    "color_rgb": cell_color.tolist(),
                    "data_label": data_label_text,
                    "cell_bbox": cell["xyxy"],
                    "cell_confidence": cell.get("conf", 1.0)
                }
                
                elements.append(element)
            
            result.elements = elements
            result.diagnostics = {
                "total_cells": len(chart_elements),
                "extracted_cells": len(elements),
                "extraction_rate": len(elements) / len(chart_elements) if chart_elements else 0,
                "grid_shape": (len(y_labels), len(x_labels)),
                "has_color_bar": len(color_bar) > 0,
                "has_data_labels": len(data_labels_dict) > 0
            }
            
            self.logger.info(
                "Extracted %d/%d cells (%.1f%%) in %dx%d grid",
                len(elements), len(chart_elements),
                100 * len(elements) / len(chart_elements) if chart_elements else 0,
                len(y_labels), len(x_labels)
            )
        
        except Exception as e:
            self.logger.error("Heatmap processing failed: %s", e, exc_info=True)
            result.errors.append(f"Processing error: {str(e)}")
        
        return result
    
    def _classify_axis_labels(
        self,
        axis_labels: List[Dict],
        cells: List[Dict],
        image_shape: Tuple[int, int]
    ) -> Tuple[List[Dict], List[Dict]]:
        """
        Classifies axis labels into X (column) and Y (row) labels.
        
        **Algorithm:**
        - Compute bounding box of all cells (the heatmap extent)
        - X-labels are below or above the heatmap
        - Y-labels are to the left or right of the heatmap
        
        Args:
            axis_labels: All detected axis labels.
            cells: All cell bounding boxes.
            image_shape: (height, width) of image.
        
        Returns:
            Tuple of (x_labels, y_labels), each sorted by position.
        """
        if not cells:
            return [], []
        
        # Compute heatmap extent
        cell_coords = np.array([cell["xyxy"] for cell in cells])
        heatmap_left = cell_coords[:, 0].min()
        heatmap_right = cell_coords[:, 2].max()
        heatmap_top = cell_coords[:, 1].min()
        heatmap_bottom = cell_coords[:, 3].max()
        
        heatmap_center_x = (heatmap_left + heatmap_right) / 2
        heatmap_center_y = (heatmap_top + heatmap_bottom) / 2
        
        x_labels = []
        y_labels = []
        
        for label in axis_labels:
            lx1, ly1, lx2, ly2 = label["xyxy"]
            label_center_x = (lx1 + lx2) / 2
            label_center_y = (ly1 + ly2) / 2
            
            # Horizontal distance from heatmap center
            horizontal_dist = abs(label_center_x - heatmap_center_x)
            # Vertical distance from heatmap center
            vertical_dist = abs(label_center_y - heatmap_center_y)
            
            # Classify based on which direction label is further from center
            if horizontal_dist < vertical_dist:
                # Label is above or below → X-axis label
                x_labels.append(label)
            else:
                # Label is left or right → Y-axis label
                y_labels.append(label)
        
        # Sort X-labels by horizontal position (left to right)
        x_labels.sort(key=lambda lbl: (lbl["xyxy"][0] + lbl["xyxy"][2]) / 2)
        
        # Sort Y-labels by vertical position (top to bottom)
        y_labels.sort(key=lambda lbl: (lbl["xyxy"][1] + lbl["xyxy"][3]) / 2)
        
        return x_labels, y_labels
    
    def _create_spatial_bins(
        self, 
        labels: List[Dict], 
        axis: str
    ) -> np.ndarray:
        """
        Creates bin edges for spatial binning of cells.
        
        **Algorithm:**
        For labels [L1, L2, L3] with positions [p1, p2, p3]:
        Bins are: [-inf, (p1+p2)/2, (p2+p3)/2, +inf]
        
        Args:
            labels: Sorted list of labels (X or Y).
            axis: 'x' or 'y'.
        
        Returns:
            Array of bin edges for np.digitize.
        """
        if axis == 'x':
            positions = [(lbl["xyxy"][0] + lbl["xyxy"][2]) / 2 for lbl in labels]
        else:  # 'y'
            positions = [(lbl["xyxy"][1] + lbl["xyxy"][3]) / 2 for lbl in labels]
        
        if len(positions) < 2:
            return np.array([-np.inf, positions[0] if positions else 0, np.inf])
        
        # Create midpoints between consecutive labels
        midpoints = []
        for i in range(len(positions) - 1):
            midpoints.append((positions[i] + positions[i+1]) / 2)
        
        # Add boundaries
        bins = [-np.inf] + midpoints + [np.inf]
        return np.array(bins)
    
    def _find_bin(
        self,
        coord: float,
        bins: np.ndarray,
        labels: List[Dict]
    ) -> Tuple[Optional[int], Optional[str]]:
        """
        Finds which bin (label) a coordinate belongs to.
        
        Args:
            coord: X or Y coordinate of cell center.
            bins: Bin edges from _create_spatial_bins.
            labels: Corresponding labels.
        
        Returns:
            Tuple of (label_index, label_text), or (None, None) if out of bounds.
        """
        bin_idx = np.digitize(coord, bins) - 1  # -1 because digitize is 1-indexed
        
        if 0 <= bin_idx < len(labels):
            return bin_idx, labels[bin_idx].get("text", f"Label_{bin_idx}")
        else:
            return None, None
    
    def _get_bbox_center(self, xyxy: List[float]) -> Tuple[float, float]:
        """Returns (cx, cy) center of bounding box."""
        x1, y1, x2, y2 = xyxy
        return ((x1 + x2) / 2, (y1 + y2) / 2)
    
    def _sample_cell_color(
        self, 
        image: np.ndarray, 
        xyxy: List[float]
    ) -> np.ndarray:
        """
        Samples the dominant color of a cell.
        
        **Strategy:** Use median color of central 50% of cell area to avoid edges.
        
        Args:
            image: Input image in BGR format.
            xyxy: Cell bounding box.
        
        Returns:
            RGB color as np.ndarray [R, G, B].
        """
        x1, y1, x2, y2 = map(int, xyxy)
        
        # Crop to central 50% to avoid border artifacts
        w, h = x2 - x1, y2 - y1
        margin_x, margin_y = int(w * 0.25), int(h * 0.25)
        
        cx1 = max(x1 + margin_x, x1)
        cy1 = max(y1 + margin_y, y1)
        cx2 = min(x2 - margin_x, x2)
        cy2 = min(y2 - margin_y, y2)
        
        if cx2 <= cx1 or cy2 <= cy1:
            # Cell too small, use full area
            cx1, cy1, cx2, cy2 = x1, y1, x2, y2
        
        cell_crop = image[cy1:cy2, cx1:cx2]
        
        if cell_crop.size == 0:
            return np.array([128, 128, 128])  # Gray default
        
        # Convert BGR to RGB and compute median
        cell_rgb = cv2.cvtColor(cell_crop, cv2.COLOR_BGR2RGB)
        median_color = np.median(cell_rgb.reshape(-1, 3), axis=0)
        
        return median_color.astype(np.uint8)
    
    def _find_overlapping_data_label(
        self,
        cell_xyxy: List[float],
        data_labels: List[Dict]
    ) -> Optional[str]:
        """
        Finds a data label that overlaps with a cell (if any).
        
        Args:
            cell_xyxy: Cell bounding box.
            data_labels: List of data label detections with OCR text.
        
        Returns:
            Text of overlapping label, or None.
        """
        cx1, cy1, cx2, cy2 = cell_xyxy
        cell_center_x = (cx1 + cx2) / 2
        cell_center_y = (cy1 + cy2) / 2
        
        for label in data_labels:
            lx1, ly1, lx2, ly2 = label["xyxy"]
            
            # Check if label center is inside cell
            if lx1 <= cell_center_x <= lx2 and ly1 <= cell_center_y <= ly2:
                return label.get("text", "")
        
        return None
    
    def _create_default_color_mapper(self):
        """Creates a simple grayscale intensity mapper as fallback."""
        def mapper(rgb_color: np.ndarray) -> float:
            # Convert to grayscale and normalize to [0, 1]
            gray = 0.299 * rgb_color[0] + 0.587 * rgb_color[1] + 0.114 * rgb_color[2]
            return gray / 255.0
        return mapper
