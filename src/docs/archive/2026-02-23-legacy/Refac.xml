    output_dir: Optional[Path] = None,
) -> Optional[Dict]:
    """
    Processes a single chart image with support for diverse chart types.
    
    MODIFICATIONS:
    - Uses DetectionResult instead of raw lists
    - Passes keypoint data to orchestrator for pie charts
    - Handles massive detection counts (heatmaps) efficiently
    """
    
    # ... (image loading code remains the same)
    
