    orchestrator = ChartAnalysisOrchestrator(
        calibration_service=calibration_engine,
        logger=logging.getLogger("Orchestrator")
    )
    
    # For pie charts, pass keypoint data via kwargs
    kwargs = {}
    if chart_type == "pie":
        kwargs["legend_elements"] = detection_result.detections_by_class.get("legend", [])
    
    result = orchestrator.process_chart(
        image=image,
        chart_type=chart_type,
        detections=detection_result.detections_by_class,
        axis_labels=axis_labels,
        chart_elements=chart_elements,
        orientation=orientation,
        **kwargs
    )
    
