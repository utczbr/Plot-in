"""
Chart analysis orchestrator with flexible service injection for diverse chart types.

ARCHITECTURAL CHANGES FROM ORIGINAL:
- Handlers are now instantiated with only the services they need
- _initialize_handlers() inspects handler requirements via class hierarchy
- New handlers (heatmap, pie) integrate seamlessly without modifying orchestrator logic
"""

import logging
from pathlib import Path
from typing import Any, Dict, List, Optional, Type
import numpy as np

from core.classifiers.production_classifier import ProductionSpatialClassifier
from core.exceptions import *

# Import all handler implementations
from handlers.base_handler import (
    BaseHandler,
    CartesianChartHandler,
    GridChartHandler,
    PolarChartHandler,
    ExtractionResult,
    ChartCoordinateSystem
)
from handlers.bar_handler import BarHandler
from handlers.box_handler import BoxHandler
from handlers.histogram_handler import HistogramHandler
from handlers.line_handler import LineHandler
from handlers.scatter_handler import ScatterHandler
from handlers.heatmap_handler import HeatmapHandler  # NEW
from handlers.pie_handler import PieHandler  # NEW

from services.dual_axis_service import DualAxisDetectionService
from services.meta_clustering_service import MetaClusteringService
from services.orientation_service import Orientation, OrientationService
from services.color_mapping_service import ColorMappingService  # NEW
from services.legend_matching_service import LegendMatchingService  # NEW


class ChartAnalysisOrchestrator:
    """
    Main orchestrator supporting diverse chart types with flexible service injection.
    
    **Design Pattern: Service Locator + Dependency Injection Hybrid**
    - The orchestrator maintains a registry of shared services
    - Handlers declare their dependencies via their base class
    - The orchestrator injects only relevant services during handler initialization
    """
    
    # Registry of all handler classes by chart type
    _HANDLER_CLASSES: Dict[str, Type[BaseHandler]] = {
        # Cartesian charts
        "bar": BarHandler,
        "scatter": ScatterHandler,
        "line": LineHandler,
        "box": BoxHandler,
        "histogram": HistogramHandler,
        # Grid charts
        "heatmap": HeatmapHandler,
        # Polar charts
        "pie": PieHandler,
    }
    
    def __init__(
        self,
        calibration_service: Any,
        hyperparams_path: Path = Path("lylaa_hypertuning_results.json"),
        logger: Optional[logging.Logger] = None,
    ):
        """
        Initializes the orchestrator with all available services.
        
        Args:
            calibration_service: Calibration engine for Cartesian charts.
            hyperparams_path: Path to LYLAA hyperparameters.
            logger: Logger instance.
        """
        self.logger = logger or logging.getLogger(__name__)
        
        # Initialize ALL available services (service pool)
        self.calibration_service = calibration_service
        self.spatial_classifier = ProductionSpatialClassifier(hyperparams_path=hyperparams_path)
        self.dual_axis_service = DualAxisDetectionService()
        self.meta_clustering_service = MetaClusteringService()
        self.color_mapper = ColorMappingService()  # NEW: for heatmaps
        self.legend_matcher = LegendMatchingService()  # NEW: for pie charts
        
        # Initialize handlers with selective service injection
        self.handlers = self._initialize_handlers()
        
        self.logger.info(
            "ChartAnalysisOrchestrator initialized with %d handlers: %s",
            len(self.handlers),
            ", ".join(self.get_supported_chart_types())
        )
    
    def _initialize_handlers(self) -> Dict[str, BaseHandler]:
        """
        Dynamically instantiates handlers with appropriate service dependencies.
        
        This method inspects each handler's base class to determine which services
        it requires and injects only those services.
        
        **Rationale:** This eliminates the need for hardcoded handler-service mappings,
        making the system truly open for extension (new handlers) without modification
        (to orchestrator logic) - adhering to the Open/Closed Principle.
        
        Returns:
            Dictionary mapping chart type names to initialized handler instances.
        """
        handlers: Dict[str, BaseHandler] = {}
        
        for chart_type, handler_class in self._HANDLER_CLASSES.items():
            try:
                # Determine which services this handler needs based on its base class
                if issubclass(handler_class, CartesianChartHandler):
                    # Cartesian charts require calibration and spatial classification
                    handler = handler_class(
                        calibration_service=self.calibration_service,
                        spatial_classifier=self.spatial_classifier,
                        dual_axis_service=self.dual_axis_service,
                        meta_clustering_service=self.meta_clustering_service,
                        logger=self.logger,
                    )
                    self.logger.debug(
                        "Initialized Cartesian handler for '%s' with calibration",
                        chart_type
                    )
                
                elif issubclass(handler_class, GridChartHandler):
                    # Grid charts (heatmaps) require color mapping
                    handler = handler_class(
                        color_mapper=self.color_mapper,
                        logger=self.logger,
                    )
                    self.logger.debug(
                        "Initialized Grid handler for '%s' with color mapper",
                        chart_type
                    )
                
                elif issubclass(handler_class, PolarChartHandler):
                    # Polar charts (pie) require legend matching
                    handler = handler_class(
                        legend_matcher=self.legend_matcher,
                        logger=self.logger,
                    )
                    self.logger.debug(
                        "Initialized Polar handler for '%s' with legend matcher",
                        chart_type
                    )
                
                else:
                    # Fallback: generic handler with no special services
                    handler = handler_class(logger=self.logger)
                    self.logger.warning(
                        "Handler '%s' does not inherit from known base class, "
                        "instantiated with minimal services",
                        chart_type
                    )
                
                handlers[chart_type] = handler
                
            except Exception as e:
                self.logger.error(
                    "Failed to initialize handler for '%s': %s",
                    chart_type, e, exc_info=True
                )
                # Continue initialization for other handlers
        
        return handlers
    
    def process_chart(
        self,
        image: np.ndarray,
        chart_type: str,
        detections: Dict[str, Any],
        axis_labels: List[Dict],
        chart_elements: List[Dict],
        orientation: Orientation = Orientation.VERTICAL,
        **kwargs  # Allow handler-specific parameters
    ) -> ExtractionResult:
        """
        Processes a single chart by routing to the appropriate handler.
        
        Args:
            image: Input image as NumPy array (H, W, C) in BGR format.
            chart_type: Type of chart (e.g., 'bar', 'heatmap', 'pie').
            detections: Detection results organized by class name.
            axis_labels: Detected axis labels with OCR text.
            chart_elements: Primary chart elements.
            orientation: Chart orientation (may be ignored for non-Cartesian).
            **kwargs: Handler-specific optional parameters (e.g., keypoints for pie).
        
        Returns:
            ExtractionResult with extracted data and diagnostics.
        
        Raises:
            UnsupportedChartTypeError: If chart_type is not registered.
            HandlerProcessingError: If handler processing fails.
        """
        self.logger.info(
            "Processing '%s' chart with orientation '%s'",
            chart_type, orientation.value
        )
        
        # Retrieve handler
        handler = self.handlers.get(chart_type.lower())
        if not handler:
            raise UnsupportedChartTypeError(
                chart_type=chart_type,
                supported_types=self.get_supported_chart_types()
            )
        
        try:
            # Pass all parameters to handler (it will use what it needs)
            result = handler.process(
                image=image,
                detections=detections,
                axis_labels=axis_labels,
                chart_elements=chart_elements,
                orientation=orientation,
                **kwargs  # Pass through handler-specific params
            )
            
            if result.errors:
                self.logger.error(
                    "Handler for '%s' completed with %d errors: %s",
                    chart_type, len(result.errors), result.errors
                )
            
            self.logger.info(
                "Successfully processed '%s' chart (%s), extracted %d elements",
                chart_type, result.coordinate_system.value, len(result.elements)
            )
            
            return result
            
        except Exception as e:
            self.logger.error(
                "Handler processing failed for '%s' chart: %s",
                chart_type, e, exc_info=True
            )
            raise HandlerProcessingError(chart_type=chart_type, original_exception=e) from e
    
    def get_supported_chart_types(self) -> List[str]:
        """Return list of supported chart types."""
        return list(self.handlers.keys())
