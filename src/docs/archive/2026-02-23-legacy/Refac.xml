        Args:
            slices: List of slice detections with keypoints.
        
        Returns:
            (cx, cy) coordinates of pie center.
        """
        centers = []
        for slice_det in slices:
            kpt = slice_det.get_keypoint(0)  # Keypoint 0 is slice center
            if kpt:
                centers.append((kpt[0], kpt[1]))
        
        if not centers:
            # Fallback: use median of bounding box centers
            centers = [
                ((s.xyxy[0] + s.xyxy[2]) / 2, (s.xyxy[1] + s.xyxy[3]) / 2)
                for s in slices
            ]
        
        centers_array = np.array(centers)
        median_center = np.median(centers_array, axis=0)
        return tuple(median_center)
    
    def _process_slice(
        self,
        slice_det: KeypointDetection,
        pie_center: Tuple[float, float],
        slice_idx: int
    ) -> Optional[Dict[str, Any]]:
        """
        Computes geometric properties of a single slice.
        
        Args:
            slice_det: Keypoint detection for the slice.
            pie_center: Global pie center coordinates.
            slice_idx: Index of this slice.
        
        Returns:
            Dictionary with slice properties, or None if processing fails.
        """
        # Extract keypoints
        kpt_start = slice_det.get_keypoint(1)  # Arc start
        kpt_end = slice_det.get_keypoint(4)    # Arc end
        
        if not kpt_start or not kpt_end:
            self.logger.warning(
                "Slice %d missing required keypoints (start or end)",
                slice_idx
            )
            return None
        
        cx, cy = pie_center
        
        # Compute angles using atan2 (range: -π to π)
        start_angle_rad = np.arctan2(kpt_start[1] - cy, kpt_start[0] - cx)
        end_angle_rad = np.arctan2(kpt_end[1] - cy, kpt_end[0] - cx)
        
        # Convert to degrees [0, 360)
        start_angle = np.degrees(start_angle_rad) % 360
        end_angle = np.degrees(end_angle_rad) % 360
        
        # Compute angular span (handle wraparound)
        angle_span = end_angle - start_angle
        if angle_span < 0:
            angle_span += 360
        
        # Sample slice color (from center of bounding box)
        slice_color = self._sample_slice_color(slice_det, image=None)  # Pass image if needed
        
        return {
            "slice_id": slice_idx,
            "start_angle": start_angle,
            "end_angle": end_angle,
            "angle_degrees": angle_span,
            "percentage": (angle_span / 360) * 100,  # Initial percentage
            "color_rgb": slice_color,
            "confidence": slice_det.conf,
            "label": f"Slice {slice_idx}",  # Will be updated by legend matching
            "bbox": slice_det.xyxy
        }
    
    def _normalize_percentages(
        self, 
        slices_data: List[Dict], 
        total_angle: float
    ):
        """
        Normalizes slice percentages to sum to exactly 100%.
        
        **Rationale:** Detection errors may cause total angle to deviate from 360°.
        
        Args:
            slices_data: List of slice dictionaries (modified in-place).
            total_angle: Sum of all slice angles.
        """
        if total_angle == 0:
            return
        
        normalization_factor = 360.0 / total_angle
        
        for slice_info in slices_data:
            slice_info["angle_degrees"] *= normalization_factor
            slice_info["percentage"] = (slice_info["angle_degrees"] / 360) * 100
    
    def _match_slices_to_legend(
        self,
        slices_data: List[Dict],
        legend_elements: List[Dict],
        image: np.ndarray,
        pie_center: Tuple[float, float]
    ):
        """
        Matches pie slices to legend labels using color similarity and proximity.
        
        **Algorithm:**
        1. Extract colors from legend label backgrounds
        2. For each slice, compute color distance to all legend labels
        3. Assign slice to closest legend label (with confidence threshold)
        
        Args:
            slices_data: List of slice dictionaries (modified in-place with 'label').
            legend_elements: List of legend label detections with OCR text.
            image: Input image for color sampling.
            pie_center: Pie center coordinates.
        """
        if not legend_elements:
            return
        
        # Extract legend label colors and texts
        legend_data = []
        for leg_elem in legend_elements:
            leg_color = self._sample_legend_color(image, leg_elem["xyxy"])
            leg_text = leg_elem.get("text", "Unknown")
            legend_data.append({
                "text": leg_text,
                "color": leg_color,
                "bbox": leg_elem["xyxy"]
            })
        
        # Match each slice to best legend entry
        for slice_info in slices_data:
            best_match_idx = -1
            best_color_distance = float('inf')
            
            slice_color = slice_info["color_rgb"]
            
            for leg_idx, leg_info in enumerate(legend_data):
                # Compute Euclidean color distance in RGB space
                color_dist = np.linalg.norm(slice_color - leg_info["color"])
                
                if color_dist < best_color_distance:
                    best_color_distance = color_dist
                    best_match_idx = leg_idx
            
            # Assign label if match is confident
            if best_match_idx >= 0 and best_color_distance < 100:  # Threshold
                slice_info["label"] = legend_data[best_match_idx]["text"]
                slice_info["legend_match_confidence"] = 1.0 - (best_color_distance / 255)
            else:
                slice_info["label"] = f"Slice {slice_info['slice_id']}"
                slice_info["legend_match_confidence"] = 0.0
    
    def _sample_slice_color(
        self, 
        slice_det: KeypointDetection,
        image: Optional[np.ndarray]
    ) -> np.ndarray:
        """
        Samples the dominant color of a pie slice.
        
        **Strategy:** Use median color of bounding box area.
        
        Args:
            slice_det: Slice keypoint detection.
            image: Input image (if None, returns placeholder).
        
        Returns:
            RGB color as np.ndarray [R, G, B].
        """
        if image is None:
            return np.array([128, 128, 128])  # Gray placeholder
        
        x1, y1, x2, y2 = map(int, slice_det.xyxy)
        slice_crop = image[y1:y2, x1:x2]
        
        if slice_crop.size == 0:
            return np.array([128, 128, 128])
        
        slice_rgb = cv2.cvtColor(slice_crop, cv2.COLOR_BGR2RGB)
        median_color = np.median(slice_rgb.reshape(-1, 3), axis=0)
        
        return median_color.astype(np.uint8)
    
    def _sample_legend_color(
        self, 
        image: np.ndarray, 
        xyxy: List[float]
    ) -> np.ndarray:
        """Samples color from legend label background."""
        x1, y1, x2, y2 = map(int, xyxy)
        
        # Sample left 30% of legend box (where color indicator usually is)
        w = x2 - x1
        color_region_x2 = x1 + int(w * 0.3)
        
        color_crop = image[y1:y2, x1:color_region_x2]
        
        if color_crop.size == 0:
            return np.array([128, 128, 128])
        
        color_rgb = cv2.cvtColor(color_crop, cv2.COLOR_BGR2RGB)
        median_color = np.median(color_rgb.reshape(-1, 3), axis=0)
        
        return median_color.astype(np.uint8)
