# core/utils.py (PARTIAL - only showing new/modified functions)

from core.detection_types import BoundingBox, KeypointDetection, DetectionResult

def run_inference_on_image(
    model: Any,
    image: np.ndarray,
    conf_threshold: float,
    class_map: Dict[int, str],
    return_keypoints: bool = False
) -> DetectionResult:
    """
    Runs object detection with support for bounding boxes and keypoints.
    
    Args:
        model: ONNX model session.
        image: Input image as NumPy array.
        conf_threshold: Minimum confidence threshold for detections.
        class_map: Mapping from class IDs to names.
        return_keypoints: If True, parse keypoint data from model output.
    
    Returns:
        DetectionResult containing all detections with appropriate format.
    
    Raises:
        ValueError: If model output format is unexpected.
    """
    import time
    start_time = time.time()
    
    # Preprocess image (existing logic)
    input_tensor = preprocess_image_for_yolo(image)  # Existing function
    
    # Run ONNX inference
    try:
        outputs = model.run(None, {model.get_inputs()[0].name: input_tensor})
        raw_output = outputs[0]  # Shape: (1, num_detections, feature_dim)
    except Exception as e:
        logging.error(f"ONNX inference failed: {e}")
        return DetectionResult(
            bboxes=[],
            keypoint_detections=[],
            detections_by_class={name: [] for name in class_map.values()},
            metadata={"error": str(e), "inference_time": 0.0}
        )
    
    # Parse output based on model type
    bboxes: List[BoundingBox] = []
    keypoint_detections: List[KeypointDetection] = []
    detections_by_class: Dict[str, List[Any]] = {name: [] for name in class_map.values()}
    
    if raw_output.ndim == 3:
        raw_output = raw_output[0]  # Remove batch dimension
    
    for detection in raw_output:
        # Parse common fields (first 6 values: x1, y1, x2, y2, conf, cls)
        if len(detection) < 6:
            continue
        
        x1, y1, x2, y2, conf, cls_id = detection[:6]
        
        # Filter by confidence
        if conf < conf_threshold:
            continue
        
        cls_id = int(cls_id)
        class_name = class_map.get(cls_id, "unknown")
        
        if return_keypoints and len(detection) > 6:
            # Parse keypoints (remaining values after first 6)
            # Format: [x1, y1, c1, x2, y2, c2, ..., x5, y5, c5] for 5 keypoints
            keypoint_data = detection[6:]
            
            try:
                # Reshape to (num_keypoints, 3)
                num_keypoints = len(keypoint_data) // 3
                if num_keypoints * 3 != len(keypoint_data):
                    logging.warning(f"Keypoint data length {len(keypoint_data)} not divisible by 3")
                    continue
                
                keypoints = np.array(keypoint_data).reshape(num_keypoints, 3)
                
                kpt_det = KeypointDetection(
                    xyxy=[float(x1), float(y1), float(x2), float(y2)],
                    cls=cls_id,
                    conf=float(conf),
                    class_name=class_name,
                    keypoints=keypoints
                )
                keypoint_detections.append(kpt_det)
                detections_by_class[class_name].append(kpt_det)
                
            except Exception as e:
                logging.error(f"Failed to parse keypoints: {e}")
                continue
        
        else:
            # Standard bounding box detection
            bbox_det = BoundingBox(
                xyxy=[float(x1), float(y1), float(x2), float(y2)],
                cls=cls_id,
                conf=float(conf),
                class_name=class_name
            )
            bboxes.append(bbox_det)
            detections_by_class[class_name].append(bbox_det)
    
    inference_time = time.time() - start_time
    
    return DetectionResult(
        bboxes=bboxes,
        keypoint_detections=keypoint_detections,
        detections_by_class=detections_by_class,
        metadata={
            "inference_time": inference_time,
            "total_detections": len(bboxes) + len(keypoint_detections),
            "bbox_count": len(bboxes),
            "keypoint_count": len(keypoint_detections),
            "return_keypoints": return_keypoints
        }
    )
